# Ports
FRONTEND_PORT=3000

# Frontend env vars (copy to reddot-frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000
API_SECRET_KEY=your-internal-api-secret-here
CRON_SECRET=your-cron-secret-here
RDP_MID=your_merchant_id_here
RDP_SECRET_KEY=your_secret_key_here

# Backend env vars (copy to backend/.env or set in Vercel project settings)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# JWT_SECRET=your-random-32-char-secret-here
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx
# ADMIN_EMAIL=admin@admin.com
# ADMIN_PASSWORD=Admin1234!
# FRONTEND_CORS_ORIGIN=https://your-frontend.vercel.app

# Default seeded admin credentials (change after first login):
#   Email:    admin@admin.com
#   Password: Admin1234!
