# Local dev environment — copy this file to .env.local and fill in your values
# .env.local is gitignored and never committed

# Express backend URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Server-side API URL (used in Next.js API routes)
API_URL=http://localhost:4000

# Shared secret for server-to-server calls (frontend → backend)
# Must match API_SECRET_KEY in backend/.env
API_SECRET_KEY=your-internal-api-secret-here

# Cron job secret — must match CRON_SECRET in backend/.env
CRON_SECRET=your-cron-secret-here

# Red Dot Payment credentials — get from RDP merchant dashboard
RDP_MID=your_merchant_id_here
RDP_SECRET_KEY=your_secret_key_here
